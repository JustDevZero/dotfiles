#!/usr/bin/env bash

set -euo pipefail

source "$(dirname "$0")/lib.sh"

cd "$(dirname "$0")/.."
DOTFILES_ROOT="$(pwd -P)"
PACKAGES_CONF="$DOTFILES_ROOT/script/packages.conf"

manual()  { MANUAL_INSTALLS+=("$1"); }

MANUAL_INSTALLS=()

# ---------------------------------------------------------------------------
# Detect OS and package manager
# ---------------------------------------------------------------------------
IS_MACOS=false
if [ "$(uname -s)" = "Darwin" ]; then
  IS_MACOS=true
  if ! command -v brew >/dev/null 2>&1; then
    fail "Homebrew not found — install it first: https://brew.sh"
  fi
else
  # shellcheck source=detect-distro.sh
  source "$(dirname "$0")/detect-distro.sh"
fi

# ---------------------------------------------------------------------------
# Install helpers
# ---------------------------------------------------------------------------
pkg() {
  local name=$1
  awk -F'|' -v name="$name" -v col="$PKG_COL" '
    /^#/ { next }
    $1 == name { print $col; exit }
  ' "$PACKAGES_CONF"
}

install_pkg() {
  local name=$1
  local resolved
  resolved=$(pkg "$name")
  if [ -z "$resolved" ]; then
    warn "no package mapping for '$name' on this distro — skipping"
    return
  fi
  info "installing $resolved..."
  install_cmd "$resolved" && success "$resolved installed" || warn "$resolved install failed — skipping"
}

install_brew() {
  local formula=$1
  info "installing $formula via brew..."
  brew install "$formula" && success "$formula installed" || warn "$formula install failed — skipping"
}

install_brew_cask() {
  local cask=$1
  info "installing $cask via brew cask..."
  brew install --cask "$cask" && success "$cask installed" || warn "$cask install failed — skipping"
}

# ---------------------------------------------------------------------------
# Detect environment
# ---------------------------------------------------------------------------
is_raspberry_pi() {
  grep -qi "raspberry pi" /sys/firmware/devicetree/base/model 2>/dev/null
}

has_battery() {
  ls /sys/class/power_supply/BAT* >/dev/null 2>&1
}

is_wayland() {
  [ "${XDG_SESSION_TYPE:-}" = "wayland" ] || [ -n "${WAYLAND_DISPLAY:-}" ]
}

is_gnome() {
  case "${XDG_CURRENT_DESKTOP:-${DESKTOP_SESSION:-}}" in
    *GNOME*|*gnome*) return 0 ;;
  esac
  return 1
}

# ---------------------------------------------------------------------------
# Install
# ---------------------------------------------------------------------------
echo ''
info "detecting environment..."

if [ "$IS_MACOS" = true ]; then

  # Screenshot — macOS has built-in screencapture, no extra tool needed
  success "screenshot: using built-in screencapture"

  # Image viewer
  install_brew_cask "xee"         # lightweight native image viewer for macOS

  # PDF viewer — Preview is built-in
  success "PDF viewer: using built-in Preview"

  # Ghostscript (for man2pdf)
  install_brew "ghostscript"

  # LibreOffice
  install_brew_cask "libreoffice"

  # GIMP
  install_brew_cask "gimp"

  # Inkscape
  install_brew_cask "inkscape"

  # Temperature — osx-cpu-temp for CLI (used by logo.sh), stats for menu bar
  install_brew "osx-cpu-temp"
  install_brew_cask "stats"

else

  # Screenshot tool
  if is_wayland; then
    info "Wayland detected — installing grim"
    install_pkg screenshot_wl
  else
    info "X11 detected — installing scrot"
    install_pkg screenshot_x11
  fi

  # Image viewer
  if is_wayland; then
    install_pkg image_viewer_wl
  else
    install_pkg image_viewer_x11
  fi

  # PDF viewer
  if is_gnome; then
    install_pkg pdf_gnome
  else
    install_pkg pdf_fallback
  fi

  # Temperature sensors (skip on Raspberry Pi, uses vcgencmd instead)
  if is_raspberry_pi; then
    info "Raspberry Pi detected — skipping lm-sensors (uses vcgencmd)"
  else
    install_pkg sensors
  fi

  # Battery tools (only if battery present)
  if has_battery; then
    info "battery detected — installing acpi and upower"
    install_pkg battery_acpi
    install_pkg battery_upower
  else
    info "no battery detected — skipping acpi/upower"
  fi

  # Ghostscript (for man2pdf)
  install_pkg ghostscript

  # LibreOffice
  install_pkg office

  # GIMP
  install_pkg gimp

  # Inkscape
  install_pkg inkscape

fi

# ---------------------------------------------------------------------------
# Summary of manual installs required
# ---------------------------------------------------------------------------
if [ "${#MANUAL_INSTALLS[@]}" -gt 0 ]; then
  echo ''
  warn "the following require manual installation:"
  for item in "${MANUAL_INSTALLS[@]}"; do
    printf '      • %s\n' "$item"
  done
fi

echo ''
success "desktop install complete"
