#!/usr/bin/env bash

set -euo pipefail

source "$(dirname "$0")/lib.sh"

cd "$(dirname "$0")/.."

update_dotfiles() {
  info "updating dotfiles repo..."
  local version_before
  version_before="$(git describe --tags --abbrev=0 2>/dev/null || printf 'untagged')"
  if git pull --rebase origin main 2>/dev/null; then
    git fetch --tags --quiet 2>/dev/null || true
    local version_after
    version_after="$(git describe --tags --abbrev=0 2>/dev/null || printf 'untagged')"
    if [ "$version_before" != "$version_after" ]; then
      success "dotfiles updated: $version_before → $version_after"
    else
      success "dotfiles up to date ($version_after)"
    fi
  else
    warn "dotfiles update failed — skipping"
  fi
}

update_submodules() {
  info "updating submodules..."
  if git submodule update --remote --merge; then
    success "submodules up to date"
  else
    warn "submodule update failed — skipping"
  fi
}

update_uv() {
  if ! command -v uv &>/dev/null; then
    warn "uv not installed, skipping"
    return
  fi
  info "updating uv..."
  if uv self update 2>/dev/null; then
    success "uv updated ($(uv --version))"
  else
    warn "uv update failed — skipping"
  fi
}

update_mise() {
  if ! command -v mise &>/dev/null; then
    warn "mise not installed, skipping"
    return
  fi
  info "updating mise..."
  if mise self-update --yes 2>/dev/null; then
    success "mise updated ($(mise --version))"
  else
    warn "mise update failed — skipping"
  fi
}

update_starship() {
  if ! command -v starship &>/dev/null; then
    warn "starship not installed, skipping"
    return
  fi
  info "updating starship..."
  if curl -sS https://starship.rs/install.sh | sh -s -- --yes --bin-dir "$HOME/.local/bin" 2>/dev/null; then
    success "starship updated ($(starship --version | head -1))"
  else
    warn "starship update failed — skipping"
  fi
}

update_bofh_excuses() {
  local dest="$HOME/.bofh-excuses"
  if [ ! -d "$dest" ]; then
    warn "bofh-excuses not installed, skipping"
    return
  fi
  info "updating bofh-excuses..."
  if git -C "$dest" pull --rebase origin main 2>/dev/null; then
    success "bofh-excuses up to date"
  else
    warn "bofh-excuses update failed — skipping"
  fi
}

check_updates() {
  info "checking for updates..."
  git fetch --tags --quiet 2>/dev/null || { warn "could not reach remote — are you online?"; return 1; }

  local current remote
  current="$(git describe --tags --abbrev=0 2>/dev/null || printf 'untagged')"
  remote="$(git describe --tags --abbrev=0 origin/main 2>/dev/null || printf 'untagged')"

  if [ "$current" = "$remote" ]; then
    success "dotfiles up to date ($current)"
  else
    warn "update available: $current → $remote (run script/update to apply)"
  fi
}

if [ "${1:-}" = "--check-updates" ]; then
  echo ''
  check_updates
  echo ''
  exit 0
fi

echo ''
info "updating dotfiles and tools..."
echo ''

update_dotfiles
update_submodules
update_uv
update_mise
update_starship
update_bofh_excuses

echo ''
success "update complete"
