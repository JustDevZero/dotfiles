#!/usr/bin/env bash

set -euo pipefail

cd "$(dirname "$0")/.."
DOTFILES_ROOT="$(pwd -P)"

overwrite_all=false
backup_all=false
skip_existing=false
dry_run=false

info() {
  printf '  [ \033[00;34m..\033[0m ] %s\n' "$1"
}

success() {
  printf '  [ \033[00;32mOK\033[0m ] %s\n' "$1"
}

fail() {
  printf '  [\033[0;31mFAIL\033[0m] %s\n' "$1"
  exit 1
}

usage() {
  cat <<EOF
Usage: script/bootstrap [options]

Options:
  --force          Replace existing files instead of prompting.
  --backup         Move existing files to <name>.backup instead of prompting.
  --skip-existing  Keep existing files instead of prompting.
  --dry-run        Show what would be linked without changing files.
  -h, --help       Show this help.
EOF
}

while [ "$#" -gt 0 ]; do
  case "$1" in
    --force)
      overwrite_all=true
      ;;
    --backup)
      backup_all=true
      ;;
    --skip-existing)
      skip_existing=true
      ;;
    --dry-run)
      dry_run=true
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      fail "unknown option: $1"
      ;;
  esac
  shift
done

ensure_localrc() {
  if [ "$dry_run" = true ]; then
    info "would ensure $HOME/.localrc exists"
    return
  fi

  touch "$HOME/.localrc"
  success "ensured $HOME/.localrc"
}

same_link_target() {
  [ -L "$2" ] && [ "$(readlink "$2")" = "$1" ]
}

backup_path_for() {
  local dst=$1
  local candidate="${dst}.backup"
  local index=1

  while [ -e "$candidate" ] || [ -L "$candidate" ]; do
    candidate="${dst}.backup.${index}"
    index=$((index + 1))
  done

  printf '%s' "$candidate"
}

choose_action() {
  local src=$1
  local dst=$2
  local action

  if [ "$overwrite_all" = true ]; then
    printf '%s' overwrite
    return
  fi

  if [ "$backup_all" = true ]; then
    printf '%s' backup
    return
  fi

  if [ "$skip_existing" = true ]; then
    printf '%s' skip
    return
  fi

  printf '  [ \033[0;33m??\033[0m ] File exists: %s (%s)\n' "$dst" "$(basename "$src")" >&2
  printf '      [s]kip, [o]verwrite, [b]ackup? ' >&2
  read -r -n 1 action
  printf '\n' >&2

  case "$action" in
    o|O) printf '%s' overwrite ;;
    b|B) printf '%s' backup ;;
    *) printf '%s' skip ;;
  esac
}

link_file() {
  local src=$1
  local dst=$2
  local action
  local backup_dst

  if same_link_target "$src" "$dst"; then
    success "already linked $dst"
    return
  fi

  if [ -e "$dst" ] || [ -L "$dst" ]; then
    action="$(choose_action "$src" "$dst")"

    case "$action" in
      overwrite)
        if [ "$dry_run" = true ]; then
          info "would replace $dst"
        else
          rm -rf "$dst"
          success "removed $dst"
        fi
        ;;
      backup)
        backup_dst="$(backup_path_for "$dst")"
        if [ "$dry_run" = true ]; then
          info "would move $dst to $backup_dst"
        else
          mv "$dst" "$backup_dst"
          success "moved $dst to $backup_dst"
        fi
        ;;
      skip)
        success "skipped $dst"
        return
        ;;
    esac
  fi

  if [ "$dry_run" = true ]; then
    info "would link $dst -> $src"
    return
  fi

  ln -s "$src" "$dst"
  success "linked $dst -> $src"
}

install_dotfiles() {
  local src
  local dst

  info "installing dotfile symlinks"

  while IFS= read -r src; do
    case "$(basename "$src")" in
      logo.sh.symlink)
        dst="$HOME/logo.sh" ;;
      starship.toml.symlink)
        mkdir -p "$HOME/.config/starship"
        dst="$HOME/.config/starship.toml" ;;
      config.toml.symlink)
        mkdir -p "$HOME/.config/mise"
        dst="$HOME/.config/mise/config.toml" ;;
      *)
        dst="$HOME/.$(basename "${src%.*}")" ;;
    esac
    link_file "$src" "$dst"
  done < <(find -H "$DOTFILES_ROOT" -maxdepth 2 -name '*.symlink' -not -path '*/.git/*' | sort)
}

install_uv() {
  if command -v uv &>/dev/null; then
    success "uv already installed ($(uv --version))"
    return
  fi

  if [ "$dry_run" = true ]; then
    info "would install uv"
    return
  fi

  info "installing uv..."
  if curl -LsSf https://astral.sh/uv/install.sh | sh; then
    success "uv installed"
  else
    fail "uv installation failed"
  fi
}

install_mise() {
  if command -v mise &>/dev/null; then
    success "mise already installed ($(mise --version))"
    return
  fi

  if [ "$dry_run" = true ]; then
    info "would install mise"
    return
  fi

  info "installing mise..."
  if curl -LsSf https://mise.run | sh; then
    success "mise installed"
  else
    fail "mise installation failed"
  fi
}

install_bofh_excuses() {
  local dest="$HOME/.bofh-excuses"
  if [ -d "$dest" ]; then
    success "bofh-excuses already present"
    return
  fi

  if [ "$dry_run" = true ]; then
    info "would clone bofh-devops-excuses to $dest"
    return
  fi

  info "cloning bofh-devops-excuses..."
  if git clone --depth=1 https://github.com/JustDevZero/bofh-devops-excuses.git "$dest"; then
    success "bofh-excuses installed"
  else
    fail "bofh-excuses clone failed"
  fi
}

install_starship() {
  if command -v starship &>/dev/null; then
    success "starship already installed ($(starship --version | head -1))"
    return
  fi

  if [ "$dry_run" = true ]; then
    info "would install starship"
    return
  fi

  info "installing starship..."
  if curl -sS https://starship.rs/install.sh | sh -s -- --yes --bin-dir "$HOME/.local/bin"; then
    success "starship installed"
  else
    fail "starship installation failed"
  fi
}

install_emacs_packages() {
  if ! command -v emacs &>/dev/null; then
    info "emacs not installed, skipping package bootstrap"
    return
  fi

  if [ "$dry_run" = true ]; then
    info "would bootstrap emacs packages"
    return
  fi

  info "bootstrapping emacs packages..."
  if emacs --batch \
      --load "$HOME/.emacs" \
      --eval "(package-refresh-contents)" \
      --eval "(package-install-selected-packages)" \
      2>/dev/null; then
    success "emacs packages bootstrapped"
  else
    fail "emacs package bootstrap failed"
  fi
}

install_macos_defaults() {
  if [ "$(uname -s)" != "Darwin" ]; then
    return
  fi

  if [ "$dry_run" = true ]; then
    info "would apply macOS defaults"
    return
  fi

  info "applying macOS defaults..."
  if zsh "$DOTFILES_ROOT/macos/set-defaults.sh"; then
    success "macOS defaults applied"
  else
    fail "macOS defaults failed"
  fi
}

ensure_localrc
install_uv
install_mise
install_starship
install_bofh_excuses
install_dotfiles
install_emacs_packages
install_macos_defaults

echo ''
info "running update to sync everything..."
"$(dirname "$0")/update"

echo ''
success "bootstrap complete"
