#!/bin/sh
#
# Remote bootstrap for these dotfiles — safe to run straight from a pipe:
#
#   curl -fsSL https://raw.githubusercontent.com/JustDevZero/dotfiles/main/script/install | sh
#
# Pass bootstrap flags after `-s --`:
#
#   curl -fsSL https://raw.githubusercontent.com/JustDevZero/dotfiles/main/script/install | sh -s -- --backup
#
# It clones (or updates) the repo into ${DOTFILES:-$HOME/.dotfiles} and then
# hands off to script/bootstrap. Written in POSIX sh on purpose so it behaves
# the same under `sh`, `bash` and `zsh`. Overridable via env:
#   DOTFILES        target dir   (default: $HOME/.dotfiles)
#   DOTFILES_REPO   clone URL    (default: the public GitHub repo)
#   DOTFILES_BRANCH branch       (default: main)

set -eu

REPO_URL="${DOTFILES_REPO:-https://github.com/JustDevZero/dotfiles.git}"
DEST="${DOTFILES:-$HOME/.dotfiles}"
BRANCH="${DOTFILES_BRANCH:-main}"

info() { printf '  [ \033[00;34m..\033[0m ] %s\n' "$1"; }
ok()   { printf '  [ \033[00;32mOK\033[0m ] %s\n' "$1"; }
die()  { printf '  [\033[0;31mFAIL\033[0m] %s\n' "$1" >&2; exit 1; }

command -v git >/dev/null 2>&1 || die "git is required — install it first, then re-run."

if [ -e "$DEST/.git" ]; then
  info "updating existing clone at $DEST"
  git -C "$DEST" pull --rebase --autostash origin "$BRANCH" || die "could not update $DEST"
  git -C "$DEST" submodule update --init --recursive || true
  ok "updated $DEST"
elif [ -e "$DEST" ]; then
  die "$DEST exists but is not a git clone — move it aside and re-run."
else
  info "cloning $REPO_URL into $DEST"
  git clone --recursive --branch "$BRANCH" "$REPO_URL" "$DEST" || die "clone failed"
  ok "cloned into $DEST"
fi

[ -x "$DEST/script/bootstrap" ] || chmod +x "$DEST/script/bootstrap" 2>/dev/null || true

info "running script/bootstrap"
exec "$DEST/script/bootstrap" "$@"
